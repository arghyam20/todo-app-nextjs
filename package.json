{
  "name": "todo-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 14500",
    "build": "next build",
    "start": "next start -p 14500",
    "prepare": "husky",
    "postinstall": "npm run prisma:generate && npm run prepare",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix",
    "prettier": "prettier --check \"**/*.{js,jsx,ts,tsx,json,yml,yaml,md,css,scss}\"",
    "format": "npm run lint:fix && prettier --write \"**/*.{js,jsx,ts,tsx,json,yml,yaml,md,css,scss}\"",
    "pre-commit": "npm run lint && npm run format && npm run build",
    "db:push": "prisma db push --schema=prisma/models",
    "db:migrate": "prisma migrate dev --schema=prisma/models",
    "db:generate": "prisma generate --schema=prisma/models",
    "db:studio": "prisma studio --schema=prisma/models",
    "prisma:generate": "prisma generate --schema=prisma/models",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@emotion/react": "^11.12.0",
    "@emotion/styled": "^11.12.0",
    "@hookform/resolvers": "^3.3.2",
    "@mui/icons-material": "^6.0.0",
    "@mui/material": "^6.0.0",
    "@mui/x-date-pickers": "^7.0.0",
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "date-fns": "^2.30.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.48.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "husky": "^8.0.3",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3"
  }
}
